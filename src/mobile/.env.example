# Pippen Mobile App Environment Variables

# API Base URL (default: http://localhost:8000/api)
VITE_API_BASE=http://localhost:8000/api

# Patient ID — required. No fallback is provided; leaving this empty will
# disable overnight intelligence and block data-entry sync to the backend.
# Obtain your patient ID from the Pippen backend team.
VITE_PATIENT_ID=
